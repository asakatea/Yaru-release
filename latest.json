  "changelog": {
    "zh": [
      {
        "type": "feature",
        "text": "学习路线、课程详情和学习台相关流程得到补强，匹配、访问控制与异常处理更稳定。"
      },
      {
        "type": "fix",
        "text": "Studio、书库和 Typst 预览链路修复了一批稳定性问题，预览与回退渲染更可靠。"
      },
      {
        "type": "fix",
        "text": "后端修复了若干 PostgreSQL/JSON 兼容、数值解析和题目接口问题，课程与练习相关接口更稳定。"
      },
      {
        "type": "improvement",
        "text": "个人资料页与界面语义做了无障碍修复，Windows 桌面端标签与读屏体验更清晰。"
      },
      {
        "type": "improvement",
        "text": "品牌图标与站点素材完成一轮刷新，落地页和个人页的链接与视觉细节也已同步更新。"
      },
      {
        "type": "improvement",
        "text": "Web/WASM 发布链路得到加固，资源清单、部署校验和上线同步流程更可靠。"
      }
    ],
    "en": [
      {
        "type": "feature",
        "text": "Learning roadmap, course-detail, and study-desk flows were strengthened with better matching, access control, and error handling."
      },
      {
        "type": "fix",
        "text": "Studio, library, and Typst preview flows received stability fixes, making preview and fallback rendering more reliable."
      },
      {
        "type": "fix",
        "text": "Backend fixes improved PostgreSQL/JSON compatibility, numeric parsing, and problem APIs, making course and practice endpoints more stable."
      },
      {
        "type": "improvement",
        "text": "Accessibility fixes improved profile-page semantics, labels, and screen-reader clarity on Windows desktop."
      },
      {
        "type": "improvement",
        "text": "Brand icons and site assets were refreshed, with matching link and visual updates across the landing and personal sites."
      },
      {
        "type": "improvement",
        "text": "The Web/WASM release pipeline was hardened, improving manifest handling, deploy validation, and publish synchronization."
      }
    ]
  },
