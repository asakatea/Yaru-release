        "type": "feature",
        "text": "Pomodoro timers now persist across screens and restore state."
      },
      {
        "type": "improvement",
        "text": "Mobile bottom navigation replaced with a floating capsule bar for faster access."
      },
      {
        "type": "improvement",
        "text": "Practice question bank and profile subpages now share the unified mobile shell app bar."
      },
      {
        "type": "fix",
        "text": "Learning roadmap falls back to the native view when the webview fails."
      },
      {
        "type": "improvement",
        "text": "Courses are localized and the roadmap is embedded directly."
      },
      {
        "type": "fix",
        "text": "Notes local-save recovery hardened to reduce data loss risk."
      },
      {
        "type": "fix",
        "text": "Mobile startup sync is cache-first for faster, more reliable boot."
      },
      {
        "type": "fix",
        "text": "Team lobby deduplicates rooms, joined state aligned, and empty team names handled."
      },
      {
        "type": "improvement",
        "text": "Problem graph theme colors and node styling normalized."
      },
      {
        "type": "fix",
        "text": "Profile level display switched to snowflake levels and the dead contribution card was removed."
      }
